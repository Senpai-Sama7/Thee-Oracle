{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "app.py": {
      "excludeFiles": "{tests/**,docs/**,.git/**,.github/**,.venv/**,venv/**,__pycache__/**,.pytest_cache/**,.mypy_cache/**,.hypothesis/**,archive/**}"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/app.py"
    }
  ]
}

