# Oracle Agent example environment
# Copy to .env and keep only the sections relevant to the components you run.

# ---------------------------------------------------------------------------
# Core OracleAgent runtime
# ---------------------------------------------------------------------------
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
ORACLE_MODEL_ID=gemini-2.0-flash-exp
ORACLE_PROJECT_ROOT=/absolute/path/to/your/project
ORACLE_MAX_TURNS=20
ORACLE_SHELL_TIMEOUT=60
ORACLE_HTTP_TIMEOUT=15
ORACLE_LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Optional router / MCP / skills
# ---------------------------------------------------------------------------
ORACLE_USE_MODEL_ROUTER=false
ORACLE_MODEL_CHAIN_CONFIG=config/model_chain.yaml
ORACLE_MCP_CONFIG=config/mcp_servers.yaml
ORACLE_MCP_TIMEOUT=30
ORACLE_SKILLS_DIR=skills/
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# ---------------------------------------------------------------------------
# Webhook service and GUI
# ---------------------------------------------------------------------------
# Generate strong random values before exposing these services outside local dev.
WEBHOOK_API_KEY=
ORACLE_API_KEY=
SECRET_KEY=
ORACLE_GUI_HOST=127.0.0.1
ORACLE_GUI_PORT=5001
ORACLE_GUI_CORS_ORIGINS=

# ---------------------------------------------------------------------------
# Personal agent and email worker
# ---------------------------------------------------------------------------
PERSONAL_AGENT_DB=data/personal_agent/agent_state.db
# Use dedicated, non-default RabbitMQ credentials.
RABBITMQ_URL=amqp://oracle_user:replace-with-random-password@localhost:5672/%2F
EMAIL_QUEUE=email_tasks
DLX_QUEUE=email_tasks.dlq
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=agent@example.com
SMTP_USE_TLS=true

# ---------------------------------------------------------------------------
# Knowledge worker
# ---------------------------------------------------------------------------
RABBITMQ_HOST=localhost
RABBITMQ_USER=oracle_user
RABBITMQ_PASS=replace-with-random-password
DISCOVERY_ENGINE_ID=
GCP_PROJECT_NUMBER=
SAFE_GCP_SERVICES=discoveryengine.googleapis.com

# ---------------------------------------------------------------------------
# Optional storage
# ---------------------------------------------------------------------------
GCS_BUCKET_NAME=
