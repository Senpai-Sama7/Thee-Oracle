# Oracle Agent Production Environment Configuration
# Copy this file to .env and configure for your environment

# === Google Cloud Configuration ===
GCP_PROJECT_ID=your-project-id-here
GCP_LOCATION=us-central1
ORACLE_MODEL_ID=gemini-2.0-flash-exp

# === Oracle Agent Configuration ===
ORACLE_PROJECT_ROOT=/home/donovan/Projects/replit
ORACLE_MAX_TURNS=20
ORACLE_SHELL_TIMEOUT=60
ORACLE_HTTP_TIMEOUT=15
ORACLE_LOG_LEVEL=INFO

# === Database Configuration ===
DATABASE_URL=sqlite:///data/oracle_core.db
# For production, consider PostgreSQL:
# DATABASE_URL=postgresql://user:pass@localhost:5432/oracle_db

# === RabbitMQ Configuration ===
RABBITMQ_URL=amqp://localhost:5672/
RABBITMQ_QUEUE=oracle_tasks
RABBITMQ_EXCHANGE=oracle_exchange
RABBITMQ_HOST=localhost
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# === Monitoring Configuration ===
PROMETHEUS_PORT=9090
METRICS_ENABLED=true
HEALTH_CHECK_PORT=8080

# === Security Configuration ===
ENABLE_AUTHENTICATION=false
API_KEY=your-api-key-here
JWT_SECRET=your-jwt-secret-here

# === Performance Configuration ===
MAX_CONCURRENT_SESSIONS=100
SESSION_TIMEOUT=3600
CACHE_TTL=300

# === Development Overrides ===
# DEVELOPMENT_MODE=true
# MOCK_GCP_RESPONSES=true
# SKIP_AUTHENTICATION=true
